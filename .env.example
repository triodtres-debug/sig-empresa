# Database
DATABASE_URL=postgresql://sig:secret@localhost:5432/sig_empresa?schema=public

# Auth
JWT_SECRET=change-me

# API (used by the API service itself)
PORT=3001

# Frontend (used by the web service to proxy API calls)
# In dev, defaults to http://localhost:3001
# On Railway, set to the API service URL (e.g., https://api.up.railway.app)
NEXT_PUBLIC_API_URL=
